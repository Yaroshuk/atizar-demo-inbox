# Copy this file to .env.local (gitignored) and fill ONLY what you use.
# The zero-credential demo (`npm run demo`) needs NONE of these.

# --- Database ---------------------------------------------------------------
# Postgres URL. Resolves: ATIZAR_DATABASE_URL > DATABASE_URL > the docker-compose default
# (postgres://aiworkflow:aiworkflow@localhost:5432/aiworkflow). With `docker compose up -d`
# you can leave this unset.
# DATABASE_URL=postgres://aiworkflow:aiworkflow@localhost:5432/aiworkflow

# --- LLM provider -----------------------------------------------------------
# mastra = production path (needs ANTHROPIC_API_KEY). claude-cli = local dev only (uses your
# Claude Code subscription via the macOS keychain; spawns the `claude` binary).
# PROVIDER=mastra
# ANTHROPIC_API_KEY=sk-ant-...
# MASTRA_MODEL=claude-sonnet-4-6

# --- Credential store -------------------------------------------------------
# AES master key for the encrypted per-user OAuth token store. Any strong random string,
# e.g. `openssl rand -hex 32`. Required for any OAuth integration (Gmail).
# ATIZAR_SECRET_KEY=

# --- Gmail OAuth app --------------------------------------------------------
# One-time OAuth client from Google Cloud Console -> APIs & Services -> Credentials ->
# OAuth client ID (enable the Gmail API on the project). The per-user token is obtained
# later through the in-app "Connect" button — not pasted here.
# ATIZAR_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# ATIZAR_GOOGLE_CLIENT_SECRET=...

# --- Auth (recommended) -----------------------------------------------------
# Shared bearer token guarding all mutation routes. Set it and the client sends it.
# ATIZAR_AUTH_TOKEN=
