{
  "name": "atizar-demo-inbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runnable example workflow built on the published @atizar/* framework — an inbox sorter + reply/reader/spam/important agents with human-approved actions. Clone it and play.",
  "scripts": {
    "prepare": "skills-npm",
    "predev": "lsof -tiTCP:4000 -tiTCP:5173 -sTCP:LISTEN 2>/dev/null | xargs -I{} kill -9 {} 2>/dev/null; sleep 1; true",
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "demo": "DEMO=1 concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "demo:scan-cassettes": "tsx server/scan-demo-cassettes.ts",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "db:migrate": "tsx -e \"import('@atizar/server').then(m=>m.runMigrations()).then(()=>process.exit(0))\"",
    "db:reset": "tsx -e \"import('@atizar/server').then(m=>m.resetDb()).then(()=>process.exit(0))\"",
    "db:reset:all": "tsx -e \"import('@atizar/server').then(m=>m.resetAll()).then(()=>process.exit(0))\"",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ui": "playwright test --headed",
    "ui:smoke": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.55",
    "@ai-sdk/anthropic": "^3.0.82",
    "@atizar/core": "^0.1.1",
    "@atizar/integrations": "^0.1.1",
    "@atizar/providers": "^0.1.1",
    "@atizar/react": "^0.1.1",
    "@atizar/server": "^0.1.1",
    "@electric-sql/pglite": "^0.2.17",
    "@hono/node-server": "^2.0.4",
    "@mastra/core": "^1.41.0",
    "@mastra/pg": "^1.12.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "googleapis": "^173.0.0",
    "hono": "^4.12.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.1",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.100.0",
    "skills-npm": "^1.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20.19"
  }
}
